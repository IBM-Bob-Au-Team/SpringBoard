# GitHub API Token (Optional)
# Used as a fallback when users don't provide their own token
# This helps avoid rate limiting on the GitHub API
# Get your token from: https://github.com/settings/tokens
# Required scopes: public_repo (or repo for private repos)
GITHUB_TOKEN=

# Application URL
# The base URL where your SpringBoard application is hosted
# Used for generating absolute URLs and CORS configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# IBM watsonx API Key (Optional - for future features)
# Your IBM watsonx API key for AI-powered features
# Get your key from: https://cloud.ibm.com/
WATSONX_API_KEY=

# IBM watsonx Project ID (Optional - for future features)
# Your watsonx project ID for orchestration features
# Find this in your watsonx project settings
WATSONX_PROJECT_ID=